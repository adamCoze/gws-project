# 集团工作跟进系统 - 环境变量配置
# 复制此文件为 .env 并填写实际值

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./data/gws.db

# JWT 密钥（请生成一个安全的随机字符串）
SECRET_KEY=your-secret-key-change-me

# Coze AI 配置（邮件分析）
COZE_API_TOKEN=your-coze-personal-access-token
COZE_BOT_ID=your-coze-bot-id
COZE_API_BASE=https://api.coze.cn

# 服务端口
BACKEND_PORT=8000
FRONTEND_PORT=5000
